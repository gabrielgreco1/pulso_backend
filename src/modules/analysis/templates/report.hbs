<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
    <style>
        body {
            font-family: 'Inter', sans-serif;
            -webkit-print-color-adjust: exact;
        }
        @page {
            margin: 0;
            size: A4;
        }
        .pulso-gradient-primary {
            background: linear-gradient(135deg, #0ea5e9 0%, #4f46e5 100%);
        }
        .pulso-gradient-emerald {
            background: linear-gradient(135deg, #34d399 0%, #14b8a6 100%);
        }
        .pulso-gradient-amber {
            background: linear-gradient(135deg, #fbbf24 0%, #f59e0b 100%);
        }
        .pulso-gradient-rose {
            background: linear-gradient(135deg, #f43f5e 0%, #e11d48 100%);
        }
        .pulso-dark-card {
            background: linear-gradient(135deg, #0f172a 0%, #1e293b 100%);
            color: white;
            border: 1px solid #334155;
        }
        .score-emerald { color: #10b981; }
        .score-sky { color: #0ea5e9; }
        .score-amber { color: #f59e0b; }
        .score-rose { color: #f43f5e; }
        
        .bg-emerald-500 { background-color: #10b981; }
        .bg-sky-500 { background-color: #0ea5e9; }
        .bg-amber-500 { background-color: #f59e0b; }
        .bg-rose-500 { background-color: #f43f5e; }

        .print-break-before { page-break-before: always; }
        .print-break-inside-avoid { page-break-inside: avoid; }
    </style>
</head>
<body class="bg-white text-slate-900">
    <div class="p-10 space-y-8">
        <!-- Header -->
        <div class="flex items-start justify-between border-b border-slate-100 pb-8">
            <div class="flex items-center gap-4">
                <div class="p-3 rounded-2xl pulso-gradient-primary">
                    <svg class="h-8 w-8 text-white" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <path d="M3 12h4l3-9 4 18 3-9h4" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
                    </svg>
                </div>
                <div>
                    <h1 class="text-3xl font-black tracking-tight text-slate-900">{{analysis.targetName}}</h1>
                    <p class="text-slate-500 text-sm font-medium uppercase tracking-widest">Relatório Completo de Inteligência Digital</p>
                </div>
            </div>
            <div class="text-right">
                <p class="text-xs font-bold text-slate-400 uppercase tracking-widest mb-1">Gerado em</p>
                <p class="text-sm font-bold text-slate-700">{{today}}</p>
            </div>
        </div>

        <!-- Scores -->
        <div class="grid grid-cols-3 gap-6">
            <!-- Overall Score -->
            <div class="rounded-3xl pulso-dark-card p-6 space-y-4">
                <div class="flex items-center justify-between">
                    <div class="flex items-center gap-2">
                        <div class="p-2 rounded-xl bg-white/10">
                            <svg class="h-4 w-4 text-white" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <path d="M3 12h4l3-9 4 18 3-9h4" />
                            </svg>
                        </div>
                        <span class="text-[10px] font-black uppercase tracking-widest text-slate-400">Score Pulso</span>
                    </div>
                    <span class="px-2.5 py-1 rounded-full text-[10px] font-black uppercase tracking-widest border border-white/20 text-white/80">
                        {{report.overallScore.label}}
                    </span>
                </div>
                <div class="flex items-end gap-1.5">
                    <span class="text-6xl font-black leading-none">{{report.overallScore.value}}</span>
                    <span class="text-xl text-slate-500 mb-1">/100</span>
                </div>
                <div class="h-2 w-full rounded-full bg-white/10">
                    <div class="h-full rounded-full pulso-gradient-primary" style="width: {{report.overallScore.value}}%"></div>
                </div>
                <p class="text-xs text-slate-400 leading-relaxed">{{report.overallScore.explanation}}</p>
            </div>

            <!-- Acceptance Score -->
            <div class="rounded-3xl border border-slate-200 bg-white p-6 space-y-4">
                <div class="flex items-center justify-between">
                    <div class="flex items-center gap-2">
                        <div class="p-2 rounded-xl bg-slate-100">
                            <svg class="h-4 w-4 text-slate-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>
                            </svg>
                        </div>
                        <span class="text-[10px] font-black uppercase tracking-widest text-slate-500">Aceitação Pública</span>
                    </div>
                </div>
                <div class="flex items-end gap-1.5">
                    {{#with report.acceptanceScore}}
                    <span class="text-6xl font-black leading-none {{scoreColor value}}">{{value}}</span>
                    <span class="text-xl text-slate-500 mb-1">/100</span>
                    {{/with}}
                </div>
                <div class="h-2 w-full rounded-full bg-slate-100">
                    <div class="h-full rounded-full {{barColor report.acceptanceScore.value}}" style="width: {{report.acceptanceScore.value}}%"></div>
                </div>
                <p class="text-xs text-slate-500 leading-relaxed">{{report.acceptanceScore.explanation}}</p>
            </div>

            <!-- Temperature Score -->
            <div class="rounded-3xl border border-slate-200 bg-white p-6 space-y-4">
                <div class="flex items-center justify-between">
                    <div class="flex items-center gap-2">
                        <div class="p-2 rounded-xl bg-slate-100">
                            <svg class="h-4 w-4 text-slate-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <path d="M14 4v10.54a4 4 0 1 1-4 0V4a2 2 0 0 1 4 0Z" />
                            </svg>
                        </div>
                        <span class="text-[10px] font-black uppercase tracking-widest text-slate-500">Temperatura Digital</span>
                    </div>
                </div>
                <div class="flex items-end gap-1.5">
                    {{#with report.temperatureScore}}
                    <span class="text-6xl font-black leading-none {{scoreColor value}}">{{value}}</span>
                    <span class="text-xl text-slate-500 mb-1">/100</span>
                    {{/with}}
                </div>
                <div class="h-2 w-full rounded-full bg-slate-100">
                    <div class="h-full rounded-full {{barColor report.temperatureScore.value}}" style="width: {{report.temperatureScore.value}}%"></div>
                </div>
                <p class="text-xs text-slate-500 leading-relaxed">{{report.temperatureScore.explanation}}</p>
            </div>
        </div>

        <!-- Executive Summary -->
        <div class="rounded-3xl border border-slate-200 overflow-hidden shadow-sm">
            <div class="bg-slate-900 px-8 py-5 flex items-center gap-3">
                <div class="bg-sky-500/20 p-2 rounded-xl">
                    <svg class="h-5 w-5 text-sky-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M3 12h4l3-9 4 18 3-9h4" />
                    </svg>
                </div>
                <div>
                    <h3 class="text-lg font-bold text-white tracking-tight">Resumo Pulso</h3>
                    <p class="text-[10px] text-slate-400 font-black uppercase tracking-widest">Visão Estratégica IA</p>
                </div>
            </div>
            <div class="p-8 bg-slate-50/30">
                <div class="text-[15px] text-slate-700 leading-relaxed font-medium">
                    {{{markdown report.executiveSummary}}}
                </div>
            </div>
        </div>

        <!-- Digital Street (Social Media) -->
        <div class="rounded-3xl border border-slate-200 overflow-hidden shadow-sm print-break-inside-avoid">
            <div class="bg-slate-900 px-8 py-5 flex items-center justify-between">
                <div class="flex items-center gap-3">
                    <div class="bg-indigo-500/20 p-2 rounded-xl">
                        <svg class="h-5 w-5 text-indigo-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>
                        </svg>
                    </div>
                    <div>
                        <h3 class="text-lg font-bold text-white tracking-tight">Voz das Redes</h3>
                        <p class="text-[10px] text-slate-400 font-black uppercase tracking-widest">Sentimento da "Rua Digital"</p>
                    </div>
                </div>
                <div class="flex gap-4">
                    <div class="text-right">
                        <p class="text-[9px] font-black text-slate-500 uppercase tracking-widest">Aceitação</p>
                        <p class="text-xl font-black text-emerald-400">{{report.socialMediaAnalysis.acceptanceRate}}%</p>
                    </div>
                </div>
            </div>
            <div class="p-8 space-y-6">
                <p class="text-slate-700 font-medium leading-relaxed">{{report.socialMediaAnalysis.summary}}</p>
                
                <div class="grid grid-cols-2 gap-4">
                    {{#each report.socialMediaAnalysis.detailedPoints}}
                    <div class="flex items-start gap-3 p-4 rounded-2xl bg-white border border-slate-100 shadow-sm">
                        <div class="mt-1 w-1.5 h-1.5 rounded-full bg-sky-500 shrink-0"></div>
                        <p class="text-[13px] text-slate-600 font-medium leading-snug">{{this}}</p>
                    </div>
                    {{/each}}
                </div>
            </div>
        </div>

        <!-- News Snapshot -->
        <div class="rounded-3xl border border-slate-200 overflow-hidden shadow-sm print-break-before">
            <div class="bg-slate-900 px-8 py-5 flex items-center gap-3">
                <div class="bg-emerald-500/20 p-2 rounded-xl">
                    <svg class="h-5 w-5 text-emerald-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M4 22h16a2 2 0 0 0 2-2V4a2 2 0 0 0-2-2H8a2 2 0 0 0-2 2v16a2 2 0 0 1-2 2Z"/><path d="M18 14h-8"/><path d="M15 18h-5"/><path d="M10 6h8v4h-8V6Z"/>
                    </svg>
                </div>
                <div>
                    <h3 class="text-lg font-bold text-white tracking-tight">Destaques da Mídia</h3>
                    <p class="text-[10px] text-slate-400 font-black uppercase tracking-widest">Snapshot das Principais Notícias</p>
                </div>
            </div>
            <div class="divide-y divide-slate-100">
                {{#each articles}}
                <div class="p-6 hover:bg-slate-50 transition-all flex items-center justify-between gap-6 print-break-inside-avoid">
                    <div class="space-y-1.5 flex-1">
                        <div class="flex items-center gap-2">
                            <span class="text-[10px] font-black uppercase tracking-widest text-slate-400">{{portal}}</span>
                            <span class="text-slate-300">•</span>
                            <span class="text-[10px] font-bold text-slate-400">{{formatDate publishedAt}}</span>
                        </div>
                        <h4 class="text-[15px] font-bold text-slate-800 leading-tight">{{title}}</h4>
                        <p class="text-xs text-slate-500 font-medium line-clamp-1">{{aiAnalysis.summary}}</p>
                    </div>
                    <div class="shrink-0 text-center px-4 py-2 rounded-2xl bg-slate-50 border border-slate-100">
                        <p class="text-[9px] font-black text-slate-400 uppercase tracking-widest mb-1">Impacto</p>
                        <p class="text-lg font-black {{sentimentColor aiAnalysis.sentiment}}">{{sentimentPct aiAnalysis.sentiment}}</p>
                    </div>
                </div>
                {{/each}}
            </div>
        </div>

        <!-- Strategic Recommendations -->
        <div class="grid grid-cols-2 gap-8 print-break-before">
            <!-- Strengths -->
            <div class="space-y-6">
                <div class="flex items-center gap-3">
                    <div class="p-2.5 rounded-2xl bg-emerald-500 group">
                        <svg class="h-5 w-5 text-white" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M12 2L15.09 8.26L22 9.27L17 14.14L18.18 21.02L12 17.77L5.82 21.02L7 14.14L2 9.27L8.91 8.26L12 2Z" />
                        </svg>
                    </div>
                    <h3 class="text-xl font-black tracking-tight text-slate-900">Pontos Fortes</h3>
                </div>
                <div class="space-y-4">
                    {{#each report.strengths}}
                    <div class="p-6 rounded-3xl bg-emerald-50/30 border border-emerald-100 space-y-2">
                        <h4 class="font-bold text-emerald-900 text-base">{{this.title}}</h4>
                        <p class="text-sm text-emerald-700/80 leading-relaxed font-medium">{{this.description}}</p>
                    </div>
                    {{/each}}
                </div>
            </div>

            <!-- Risks -->
            <div class="space-y-6">
                <div class="flex items-center gap-3">
                    <div class="p-2.5 rounded-2xl bg-rose-500">
                        <svg class="h-5 w-5 text-white" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/>
                        </svg>
                    </div>
                    <h3 class="text-xl font-black tracking-tight text-slate-900">Riscos e Críticas</h3>
                </div>
                <div class="space-y-4">
                    {{#each report.weaknesses}}
                    <div class="p-6 rounded-3xl bg-rose-50/30 border border-rose-100 space-y-2">
                        <h4 class="font-bold text-rose-900 text-base">{{this.title}}</h4>
                        <p class="text-sm text-rose-700/80 leading-relaxed font-medium">{{this.description}}</p>
                    </div>
                    {{/each}}
                </div>
            </div>
        </div>
    </div>
</body>
</html>
